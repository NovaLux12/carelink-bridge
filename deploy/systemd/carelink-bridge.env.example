# carelink-bridge environment file
#
# Copy to /home/jack/carelink-bridge/.env (same directory as the
# service's WorkingDirectory) and `chmod 600` it. The systemd unit
# loads this via EnvironmentFile=.
#
# Required:
CARELINK_USERNAME=your-carelink-username
CARELINK_PASSWORD=your-carelink-password
API_SECRET=your-nightscout-api-secret
NS=https://your-nightscout-site.example.com

# Required for US users (default is EU):
# MMCONNECT_SERVER=US

# Optional:
# MMCONNECT_COUNTRYCODE=gb   # default
# MMCONNECT_LANGCODE=en      # default
# CARELINK_INTERVAL=300      # seconds, default 5 min
# CARELINK_SGV_LIMIT=24      # default
# CARELINK_QUIET=false       # set false for verbose logs
# CARELINK_PATIENT=          # only if your care-partner account has multiple patients
